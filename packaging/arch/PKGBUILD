# Maintainer: Kirill <helmutbecker146@gmail.com>

pkgname=synapse-notes
pkgver=0.1.2
pkgrel=1
pkgdesc="Личные заметки: редактор в духе Notion и граф связей как в Obsidian"
arch=('x86_64')
url="https://github.com/Mutata56/Synapse"
license=('GPL-3.0-only')
depends=('webkit2gtk-4.1' 'gtk3' 'libayatana-appindicator' 'librsvg' 'hicolor-icon-theme')
makedepends=('rust' 'cargo' 'nodejs' 'npm')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('4839377ba2a22f43c3feb25b77fb37177f0f9b78a8ddba2f20327e2fb7ed2f93')

build() {
  cd "Synapse-$pkgver"
  npm ci
  # --no-bundle: нужен только нативный бинарь (без deb/rpm/appimage). Линкуется с
  # системным webkit, поэтому интерфейс рисуется — в отличие от AppImage с чужим
  # бандлом webkit, который на свежих системах даёт серый экран.
  npm run tauri build -- --no-bundle
}

package() {
  cd "Synapse-$pkgver"

  install -Dm755 "src-tauri/target/release/synapse" "$pkgdir/usr/bin/synapse"

  install -Dm644 "src-tauri/icons/128x128.png" \
    "$pkgdir/usr/share/icons/hicolor/128x128/apps/synapse.png"
  install -Dm644 "src-tauri/icons/32x32.png" \
    "$pkgdir/usr/share/icons/hicolor/32x32/apps/synapse.png"

  install -d "$pkgdir/usr/share/applications"
  cat > "$pkgdir/usr/share/applications/synapse.desktop" <<'DESKTOP'
[Desktop Entry]
Type=Application
Name=Synapse
GenericName=Заметки
Comment=Личные заметки: Notion-редактор и граф связей
Exec=synapse
Icon=synapse
Terminal=false
Categories=Office;TextEditor;Utility;
StartupWMClass=synapse
Keywords=notes;notion;obsidian;заметки;
DESKTOP
}
