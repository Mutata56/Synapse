{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synapse",
  "version": "0.1.0",
  "identifier": "com.kirill.synapse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Synapse",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      },
      {
        "label": "capture",
        "title": "Быстрая заметка",
        "width": 560,
        "height": 240,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPDATA/**/.*", "$APPDATA/**/.*/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
